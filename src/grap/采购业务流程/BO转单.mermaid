sequenceDiagram
    autonumber
    box Grey 业务系统
        participant a1 as 工单系统
        participant a2 as BPM审核
        participant a3 as 座舱服务
        participant a4 as 权益中心
    end
    box Blue 下游服务
        participant a5 as 维保服务
        participant a6 as 卡券服务
    end

    activate a1
    rect rgb(240,240,240)
        note over a1,a2: 审核阶段
        a1 ->>+ a2: 同步调用审核接口
        alt 审核不通过
            a2 ->> a1: !驳回申请(同步返回)
            deactivate a2
            a1 ->> a1: 记录驳回原因
        else 审核通过
            a2 -->> a1: 返回审核成功
            deactivate a2
        end
    end

    rect rgb(240,240,240)
        note over a3,a6: 权益恢复阶段（异步处理）
        par 并行恢复
            a1 ->>+ a3: 异步消息：恢复车主标签
            a3 -->>- a1: 处理结果
        and
            a1 ->>+ a4: 异步消息：恢复首任车主权益
            a4 ->>+ a5: 调用维保API
            a5 -->>- a4: 返回结果
            a4 ->>+ a6: 调用卡券API
            a6 -->>- a4: 返回结果
            a4 -->> a1: 汇总处理结果
        end
    end

    rect rgb(240,240,240)
        note over a1: 终态处理
        alt 全部成功
            a1 ->> a1: 自动关单
        else 存在失败
            loop 重试机制
                a1 ->> a1: 记录失败项并重试
            end
            a1 ->> a3: 触发人工干预
        end
        deactivate a1
    end