erDiagram
    equity_package ||--o{ equity_config : "1:N 包含"
    equity_package ||--o{ package_grant : "1:N 发放"
    equity_config ||--o{ equity_grant : "1:N 发放"
    equity_config ||--o{ equity_grant_detail : "1:N 详情"
    package_grant ||--o{ equity_grant : "1:N 关联"
    equity_grant ||--o{ equity_grant_detail : "1:N 详情"
    equity_grant ||--o{ performance_record : "1:N 使用"
    equity_grant_detail ||--o{ performance_record : "1:N 使用"
    package_grant ||--o{ package_grant : "1:N 主包关联"
    performance_record ||--o{ reconciliation_log : "1:N 对账"

    equity_package {
        bigint package_id PK "主键"
        string package_key UK "业务唯一标识"
        string package_name "权益包名称"
        string display_type "显示类型"
        boolean valid "是否有效"
        text package_config "包内容配置"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
        string create_user "创建人"
        string update_user "更新人"
        text extra_info "额外信息"
        string car_edition_ssu_ids "车型商品ssuId"
        int authority_strategy "退款和购买权限策略"
        bigint business_id "业务ID"
    }

    equity_config {
        bigint equity_id PK "主键"
        string equity_key UK "业务唯一标识"
        bigint package_id FK "权益包ID"
        string package_key "权益包Key"
        string equity_name "权益名称"
        string equity_form "权益履约形式"
        text rule_detail "具体发放规则详情"
        text description "权益描述"
        boolean need_show "是否展示"
        boolean valid "是否有效"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
        string create_user "创建人"
        string update_user "更新人"
        int first_car_owner "是否首任车主专属权益"
    }

    package_grant {
        bigint package_grant_id PK "主键"
        bigint package_id FK "权益包ID"
        string package_key "权益包键"
        string vid "车辆VID"
        bigint mid "用户MID"
        bigint main_package_grant_id FK "主包ID"
        bigint order_id "订单ID"
        string car_type "车辆类型"
        int goods_count "订单中物品数量"
        decimal amount "金额"
        bigint trade_time "交易时间"
        datetime start_time "生效开始时间"
        datetime end_time "生效结束时间"
        int order_status "订单状态"
        int valid "是否有效"
        datetime invalid_time "失效时间"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
    }

    equity_grant {
        bigint equity_grant_id PK "主键"
        bigint package_grant_id FK "包发放ID"
        bigint equity_id FK "权益ID"
        string vid "车辆VID"
        bigint mid "用户MID"
        int limit "限制次数"
        int used_count "已使用次数"
        int goods_count "订单中商品数量"
        datetime start_time "生效开始时间"
        datetime end_time "生效结束时间"
        string equity_form "权益履约形式"
        text rule_detail "具体发放规则详情"
        int valid "是否有效"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
    }

    equity_grant_detail {
        bigint equity_grant_detail_id PK "主键"
        bigint equity_id FK "权益ID"
        bigint equity_grant_id FK "权益授予ID"
        bigint mid "用户MID"
        string vid "车辆VID"
        string impl_ability_id "实现能力ID"
        datetime start_time "开始时间"
        datetime end_time "结束时间"
        int valid "状态:0-作废,1-有效,2-待发放"
        datetime invalid_time "失效时间"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
        text ext "下发详情json"
    }

    performance_record {
        bigint performance_record_id PK "主键"
        string vid "车辆VID"
        bigint mid "用户MID"
        bigint equity_id FK "权益ID"
        bigint equity_grant_id FK "权益授予ID"
        bigint equity_grant_detail_id FK "权益授予详情ID"
        string idempotent_id "幂等ID"
        string usage_record_id "使用记录ID"
        bigint usage_order_id "使用订单ID"
        string usage_st_no "超级工单号"
        datetime usage_start_time "使用开始时间"
        datetime usage_end_time "使用结束时间"
        boolean valid "是否有效"
        datetime invalid_time "失效时间"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
    }

    reconciliation_log {
        bigint reconciliation_log_id PK "主键"
        datetime start_time "数据范围开始时间"
        datetime end_time "数据范围结束时间"
        string vid "车辆VID"
        text right_performance_record_ids "正确履约记录IDs"
        text wrong_performance_record_detail "错误履约记录详情"
        boolean corrected "是否已纠正"
        datetime create_time "创建时间"
        datetime update_time "更新时间"
    }